#!/bin/sh
# Установщик z4r с веб-интерфейсом
# Использование: curl -O https://raw.githubusercontent.com/Koviand/z4r/4/z4r_mod && sh z4r_mod

BRANCH="4"
REPO="Koviand/z4r"
RAW_URL="https://raw.githubusercontent.com/${REPO}/${BRANCH}"
INSTALL_DIR="/opt"

# Проверка прав root
[ "$UID" != "0" ] && [ ! -d /opt/bin ] && [ ! -d /jffs/scripts ] && {
    echo "⚠ Возможно скрипт запущен без прав root (sudo)"
}

# Проверка wget или curl
if which curl >/dev/null 2>&1; then
    DL_CMD="curl -sS -L -o"
    DL_TIMEOUT="--max-time 30"
elif which wget >/dev/null 2>&1; then
    DL_CMD="wget -q -O"
    DL_TIMEOUT="-T 30"
else
    echo "❌ Ошибка: wget или curl не найдены"
    exit 1
fi

echo "=== Установка z4r с веб-интерфейсом ==="
echo "Репозиторий: ${REPO}"
echo "Ветка: ${BRANCH}"
echo ""

# Создаем директории
mkdir -p "${INSTALL_DIR}/zapret"
mkdir -p "${INSTALL_DIR}/zapret/lib"

echo "Загрузка основных компонентов..."

# Загрузка основного скрипта z4r.sh
if $DL_CMD "${INSTALL_DIR}/z4r.sh" $DL_TIMEOUT "${RAW_URL}/zapret4rocket/z4r.sh" 2>/dev/null; then
    chmod +x "${INSTALL_DIR}/z4r.sh"
    echo "✓ z4r.sh загружен"
else
    echo "❌ Ошибка загрузки z4r.sh"
    exit 1
fi

# Загрузка библиотек
LIB_FILES="ui.sh provider.sh telemetry.sh recommendations.sh netcheck.sh premium.sh strategies.sh submenus.sh actions.sh dependencies.sh error_handler.sh file_operations.sh healthcheck.sh logging_wrapper.sh logging.sh retry.sh validation.sh"

echo "Загрузка библиотек..."
for file in $LIB_FILES; do
    if $DL_CMD "${INSTALL_DIR}/zapret/lib/${file}" $DL_TIMEOUT "${RAW_URL}/zapret4rocket/lib/${file}" 2>/dev/null; then
        echo "  ✓ ${file}"
    else
        echo "  ⚠ ${file} - ошибка загрузки"
    fi
done

# Загрузка конфигурации по умолчанию
if $DL_CMD "${INSTALL_DIR}/zapret/config.default" $DL_TIMEOUT "${RAW_URL}/zapret4rocket/config.default" 2>/dev/null; then
    echo "✓ config.default загружен"
fi

# Загрузка скрипта установки веб-интерфейса
if $DL_CMD "${INSTALL_DIR}/zapret/install_web.sh" $DL_TIMEOUT "${RAW_URL}/zapret4rocket/install_web.sh" 2>/dev/null; then
    chmod +x "${INSTALL_DIR}/zapret/install_web.sh"
    echo "✓ install_web.sh загружен"
fi

# Загрузка конфигурации веб-интерфейса
if $DL_CMD "${INSTALL_DIR}/zapret/web_config.json" $DL_TIMEOUT "${RAW_URL}/zapret4rocket/web_config.json" 2>/dev/null; then
    echo "✓ web_config.json загружен"
fi

echo ""
echo "=== Запуск z4r.sh ==="
cd "${INSTALL_DIR}" || exit 1

# Определяем shell
if which bash >/dev/null 2>&1; then
    SHELL_CMD="bash"
elif which ash >/dev/null 2>&1; then
    SHELL_CMD="ash"
else
    SHELL_CMD="sh"
fi

# Запускаем z4r.sh
if [ -t 0 ]; then
    exec $SHELL_CMD ./z4r.sh "$@"
else
    exec $SHELL_CMD ./z4r.sh "$@" < /dev/tty
fi
